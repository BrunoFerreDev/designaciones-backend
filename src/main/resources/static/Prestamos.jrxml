		<query language="SQL"><![CDATA[SELECT prestamo.estado,
	prestamo.fecha_registro,
	prestamo.fecha_solicitud,
	prestamo.monto_devuelto,
	prestamo.monto_solicitado,
	arbitro.nombre,
	arbitro.apellido,
	arbitro.estado_sistema
FROM prestamo
	INNER JOIN arbitro ON 
	 prestamo.arbitro_id = arbitro.id_arbitro]]></query>
