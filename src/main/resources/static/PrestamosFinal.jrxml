	<dataset name="DataFinal" uuid="49ecaf27-76eb-4c76-be03-1369d6bc9b6a">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Finanzas.jrdax"/>
		<query language="SQL"><![CDATA[SELECT prestamo.monto_solicitado,
	prestamo.monto_devuelto,
	prestamo.fecha_solicitud,
	prestamo.estado,
	arbitro.nombre,
	arbitro.apellido
FROM prestamo
	INNER JOIN arbitro ON 
	 prestamo.arbitro_id = arbitro.id_arbitro]]></query>
		<field name="monto_solicitado" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="monto_solicitado"/>
			<property name="com.jaspersoft.studio.field.label" value="monto_solicitado"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="prestamo"/>
		</field>
		<field name="monto_devuelto" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="monto_devuelto"/>
			<property name="com.jaspersoft.studio.field.label" value="monto_devuelto"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="prestamo"/>
		</field>
		<field name="fecha_solicitud" class="java.sql.Date">
			<property name="com.jaspersoft.studio.field.name" value="fecha_solicitud"/>
			<property name="com.jaspersoft.studio.field.label" value="fecha_solicitud"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="prestamo"/>
		</field>
		<field name="estado" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="estado"/>
			<property name="com.jaspersoft.studio.field.label" value="estado"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="prestamo"/>
		</field>
		<field name="nombre" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="nombre"/>
			<property name="com.jaspersoft.studio.field.label" value="nombre"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="arbitro"/>
		</field>
		<field name="apellido" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="apellido"/>
			<property name="com.jaspersoft.studio.field.label" value="apellido"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="arbitro"/>
		</field>
		<variable name="total_prestamos" calculation="Sum" class="java.math.BigDecimal">
			<expression><![CDATA[$F{monto_solicitado}]]></expression>
		</variable>
		<variable name="total_devolucion" calculation="Sum" class="java.math.BigDecimal">
			<expression><![CDATA[$F{monto_devuelto}]]></expression>
		</variable>
		<variable name="total_final" class="java.math.BigDecimal">
			<expression><![CDATA[$V{total_prestamos}.subtract( $V{total_devolucion})]]></expression>
		</variable>
		<group name="monto_solicitado">
			<expression><![CDATA[$F{monto_solicitado}]]></expression>
		</group>
		<group name="monto_devuelto">
			<expression><![CDATA[$F{monto_devuelto}]]></expression>
		</group>
		<group name="fecha_solicitud">
			<expression><![CDATA[$F{fecha_solicitud}]]></expression>
		</group>
		<group name="estado">
