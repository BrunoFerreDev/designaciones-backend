	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="173"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="820"/>
	<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w1" value="411"/>
	<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w2" value="575"/>
	<parameter name="idTranssacion" forPrompting="false" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[43]]></defaultValueExpression>
	</parameter>
	<query language="sql"><![CDATA[SELECT 
    transacciones.tipo,
    transacciones.monto AS monto_total_transaccion,
    transacciones.fecha_transaccion,
    transacciones.descripcion AS transaccion_descripcion,
    concepto_gasto.descripcion AS concepto_descripcion,
    concepto_gasto.nombre AS concepto_nombre,
    deudas_gasto.id_arbitro,
    deudas_gasto.monto_asignado,
    deudas_gasto.monto_pagado,
    deudas_gasto.estado,
    CASE 
        WHEN deudas_gasto.monto_pagado >= deudas_gasto.monto_asignado OR deudas_gasto.estado = 'PAGADO' THEN 1 
        ELSE 0 
    END AS pagó,
    CASE 
        WHEN deudas_gasto.monto_pagado < deudas_gasto.monto_asignado OR deudas_gasto.estado != 'PAGADO' THEN 1 
        ELSE 0 
    END AS no_pagó
FROM deudas_gasto
INNER JOIN transacciones_gasto ON deudas_gasto.id_transaccion_gasto = transacciones_gasto.id_transaccion 
INNER JOIN transacciones ON transacciones_gasto.id_transaccion = transacciones.id_transaccion 
INNER JOIN concepto_gasto ON transacciones_gasto.concepto_gasto_id_h = concepto_gasto.id_concepto_gasto 
WHERE transacciones.id_transaccion = $P{idTranssacion}]]></query>
