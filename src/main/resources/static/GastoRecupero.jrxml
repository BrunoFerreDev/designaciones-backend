	<parameter name="idTranssacion" forPrompting="false" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[33]]></defaultValueExpression>
	</parameter>
	<query language="sql"><![CDATA[SELECT transacciones.tipo,
	transacciones.monto,
	transacciones.fecha_transaccion,
	transacciones.fecha_registro,
	transacciones.descripcion,
	concepto_gasto.descripcion,
	concepto_gasto.nombre,
	transacciones_gasto.id_transaccion,
	transacciones.id_transaccion,
	deudas_gasto.monto_pagado
FROM deudas_gasto
	INNER JOIN transacciones_gasto ON 
	 deudas_gasto.id_transaccion_gasto = transacciones_gasto.id_transaccion 
	INNER JOIN transacciones ON 
	 transacciones_gasto.id_transaccion = transacciones.id_transaccion 
	INNER JOIN concepto_gasto ON 
	 transacciones_gasto.concepto_gasto_id_h = concepto_gasto.id_concepto_gasto 
WHERE 
	 transacciones.id_transaccion = $P{idTranssacion}]]></query>
