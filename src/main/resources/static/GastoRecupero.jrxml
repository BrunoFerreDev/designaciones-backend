<jasperReport name="GastoRecupero" language="java" columnCount="1" pageWidth="800" pageHeight="595" columnWidth="760" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="16eacdcd-5393-4bd6-b66a-cfd21943630f">
