		<query language="SQL"><![CDATA[SELECT arbitro.apellido,
	arbitro.nombre,
	deudas_gasto.monto_asignado,
	deudas_gasto.monto_pagado,
	deudas_gasto.estado
FROM deudas_gasto
	INNER JOIN arbitro ON 
	 deudas_gasto.id_arbitro = arbitro.id_arbitro]]></query>
